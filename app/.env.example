# Public frontend configuration only.
# Do not put Make, Airtable, Stripe, WhatsApp, Google or other private tokens here.

# Safe public endpoint consumed by the browser. It must point to your own backend/API route.
# The frontend posts validated booking requests here; the backend then calls private services.
VITE_CP04_PUBLIC_BOOKING_ENDPOINT=/api/reservas

# Optional public contact data. These values are safe only if they are intended to be shown to users.
VITE_CP04_PUBLIC_CONTACT_EMAIL=CONFIGURAR_EMAIL_PUBLICO_REAL
VITE_CP04_PUBLIC_CONTACT_PHONE=CONFIGURAR_TELEFONO_PUBLICO_REAL

# Public SEO values to keep aligned with index.html before production.
VITE_CP04_PUBLIC_SITE_URL=https://clubpadel04.example/
VITE_CP04_PUBLIC_SEO_AREA=CONFIGURAR_ZONA_REAL

# Optional public gallery image URLs or public paths. Leave empty until real club photos exist.
VITE_CP04_PUBLIC_GALLERY_PISTAS=
VITE_CP04_PUBLIC_GALLERY_RECEPCION=
VITE_CP04_PUBLIC_GALLERY_CAFETERIA=
VITE_CP04_PUBLIC_GALLERY_TORNEOS=
VITE_CP04_PUBLIC_GALLERY_INSTALACIONES=

# Backend-only variables belong outside Vite/public frontend env files.
# Define these only in your server, API route, edge function or worker environment:
# ALLOWED_ORIGIN=https://tu-dominio.com
# MAKE_RESERVAS_WEBHOOK=
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_RESERVAS_TABLE=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# WHATSAPP_PROVIDER_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# GOOGLE_CALENDAR_CREDENTIALS=
# GOOGLE_DRIVE_CREDENTIALS=

# Future backend-only auth variables. Do not expose secrets in Vite/frontend env files.
# AUTH_PROVIDER=
# AUTH_ISSUER_URL=
# AUTH_AUDIENCE=
# AUTH_CLIENT_SECRET=
# SESSION_SECRET=
# JWT_VERIFICATION_KEY=

# Optional public auth identifiers only if your chosen provider requires them.
# VITE_CP04_PUBLIC_AUTH_PROVIDER=
# VITE_CP04_PUBLIC_AUTH_CLIENT_ID=
# VITE_CP04_PUBLIC_AUTH_DOMAIN=
